{
  "manifest_version": 3,
  "name": "SignalOnly Privacy Surface",
  "short_name": "SignalOnly",
  "version": "0.4.0",
  "description": "A near-future browser control surface for Tor routing, leak blocking, fingerprint reduction, storage isolation, PII shielding, and site profiles.",
  "minimum_chrome_version": "120",
  "permissions": [
    "declarativeNetRequest",
    "privacy",
    "proxy",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "SIGNALONLY",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "options_page": "options/options.html",
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content/content.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "baseline",
        "enabled": true,
        "path": "rules/static-rules.json"
      }
    ]
  },
  "web_accessible_resources": [
    {
      "resources": [
        "src/injected/fingerprint.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
